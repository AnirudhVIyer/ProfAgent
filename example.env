# .env.example
# ------------------------------------------------------------
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
#
# Get your API keys from:
#   Anthropic:  console.anthropic.com
#   Tavily:     tavily.com
#   Supabase:   supabase.com → your project → Settings → API
#   Cohere:     cohere.com → API Keys
#   Gmail:      myaccount.google.com → App Passwords
# ------------------------------------------------------------

# ── LLM ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Web Search ───────────────────────────────────────────────
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ─────────────────────────────────────────────────
# Project URL — found in Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon/public key — safe to use in client-side code
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# Service role key — backend only, never expose to frontend
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ── Embeddings ───────────────────────────────────────────────
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gmail SMTP ───────────────────────────────────────────────
# The Gmail address Sage sends FROM
GMAIL_SENDER=youremail@gmail.com

# App password — NOT your Gmail login password
# Generate at: myaccount.google.com → Security → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Fallback recipient if user email not found
GMAIL_RECIPIENT=youremail@gmail.com

# ── Local Testing ────────────────────────────────────────────
# Your Supabase user UUID — for running pipeline tests locally
# Find in: Supabase → Authentication → Users
TEST_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx